{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Services Up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(up{job=\"payment-ledger-services\"})", "refId": "A"}],
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "Audit Events Recorded",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(audit_events_recorded_total)", "refId": "A"}],
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (instance) (rate(http_server_requests_seconds_count[5m]))",
        "legendFormat": "{{instance}}",
        "refId": "A"
      }],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 Latency",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, instance) (rate(http_server_requests_seconds_bucket[5m])))",
        "legendFormat": "{{instance}}",
        "refId": "A"
      }],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Usage",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\"})",
        "legendFormat": "{{instance}}",
        "refId": "A"
      }],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ],
  "refresh": "15s",
  "schemaVersion": 41,
  "tags": ["payment-ledger", "operations"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "title": "Payment Ledger Platform Overview",
  "uid": "payment-ledger-overview",
  "version": 1
}
